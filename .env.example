# Скопируй в .env (НЕ коммить!). В GitHub Actions те же ключи кладутся в Secrets.

# --- ВКонтакте ---
VK_TOKEN=
VK_OWNER_ID=        # ID сообщества со знаком минус, напр. -123456789

# --- VC (Osnova) ---
VC_TOKEN=           # vc.ru -> Настройки -> Инструменты для разработчика
VC_SUBSITE_ID=      # ID блога/аккаунта, куда постим

# --- Дзен (RSS) ---
# URL, по которому будет доступен статический сайт на GitHub Pages.
# Напр. https://<логин>.github.io/vc-asfarm-poster
SITE_BASE_URL=
